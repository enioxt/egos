#!/bin/bash
# ============================================================================
# FOCUS ENFORCEMENT HOOK v2.0 — Researcher-Builder Profile
# Period: April 3 - June 30, 2026
# 
# v2.0 CHANGE: Two-tier enforcement
#   FORBIDDEN list  → HARD BLOCK  (named scope-creep traps: ARCH, FORJA, etc.)
#   Unknown files   → WARN + allow (research, tools, MCPs, skills always OK)
#
# Rationale: Enio is a researcher-builder who creates tools before demand.
# The constraint is against SPECIFIC distractions, not against curiosity.
# Work is never lost — only redirected when touching forbidden products.
# ============================================================================

# Color codes
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

# ── FORBIDDEN: These products are out-of-scope until July 2026 ──────────────
# Committing to these = hard block. Everything else = warn + allow.
FORBIDDEN_PATTERNS=(
  "ARCH/"
  "egos-self"
  "smartbuscas"
  "FORJA/"
  "EGOSv2"
  "EGOSv3"
  "EGOSv5"
  "BLUEPRINT-EGOS"
  "egos-cortex"
  "intelink"
  "DHPP/"
  "EGOSystem"
  "Pochete2.0"
  "guia-INPI"
  "chacreamento"
)

# ── FOCUS: Files clearly within Guard Brasil + Gem Hunter ───────────────────
FOCUS_PATTERNS=(
  "guard-brasil" "gem-hunter" "apps/api" "packages/shared"
  "apps/egos-gateway" "apps/egos-hq" "agents/agents" "agents/registry"
  "scripts/" "packages/mcp" "packages/knowledge" ".claude/" ".guarani"
  "TASKS.md" "AGENTS.md" "CLAUDE.md" "docs/" "business/" "supabase/"
  ".github/" ".husky/" "package.json" "tsconfig" "bun.lock"
)

STAGED_FILES=$(git diff --cached --name-only)
FORBIDDEN_HIT=0
WARN_FILES=()

for file in $STAGED_FILES; do
  [ ! -f "$file" ] && continue

  # 1. Hard block for forbidden products
  for forbidden in "${FORBIDDEN_PATTERNS[@]}"; do
    if [[ "$file" == *"$forbidden"* ]]; then
      FORBIDDEN_HIT=1
      echo -e "${RED}❌ FOCO VIOLADO: $file${NC}"
      echo -e "${YELLOW}   → Produto fora do escopo: $forbidden${NC}"
    fi
  done

  # 2. Warn (but allow) for files outside known focus paths
  if [ $FORBIDDEN_HIT -eq 0 ]; then
    IN_FOCUS=0
    for focus in "${FOCUS_PATTERNS[@]}"; do
      if [[ "$file" == *"$focus"* ]]; then
        IN_FOCUS=1; break
      fi
    done
    if [ $IN_FOCUS -eq 0 ]; then
      WARN_FILES+=("$file")
    fi
  fi
done

# Hard block for forbidden products
if [ $FORBIDDEN_HIT -eq 1 ]; then
  echo ""
  echo -e "${BLUE}═══════════════════════════════════════════════════════════${NC}"
  echo -e "${BLUE}FOCUS ENFORCEMENT v2.0 — Produtos proibidos até Jul 2026${NC}"
  echo -e "${BLUE}═══════════════════════════════════════════════════════════${NC}"
  echo -e "${RED}❌ ARCH, FORJA, egos-self, smartbuscas e similares estão fora do foco.${NC}"
  echo -e "${GREEN}✅ Guard Brasil, Gem Hunter, MCPs, skills, infra → sempre OK.${NC}"
  echo -e "${YELLOW}💡 Pesquisa e ferramentas novas → sempre permitidas (perfil researcher-builder).${NC}"
  echo -e "${BLUE}═══════════════════════════════════════════════════════════${NC}"
  exit 1
fi

# Warn (but allow) for off-focus research files
if [ ${#WARN_FILES[@]} -gt 0 ]; then
  echo -e "${YELLOW}⚠️  AVISO DE FOCO (commit permitido — perfil researcher-builder)${NC}"
  echo -e "${YELLOW}   Arquivos fora do foco principal Guard Brasil/Gem Hunter:${NC}"
  for wf in "${WARN_FILES[@]}"; do
    echo -e "${YELLOW}   → $wf${NC}"
  done
  echo -e "${BLUE}   💡 Pesquisa e ferramentas novas são válidas. Só ARCH/FORJA/etc. são bloqueados.${NC}"
  echo -e "${BLUE}   Meta: R\$ 30k MRR até Jun 2026. Guard Brasil primeiro.${NC}"
fi

echo -e "${GREEN}✅ Focus enforcement check passed${NC}"
exit 0
