# ── EGOS HQ — Environment Variables ──────────────────────────────────────────
# Copy to .env.local and fill in values

# Auth (REQUIRED — change this to a strong random string 32+ chars)
DASHBOARD_MASTER_SECRET=change-me-to-strong-random-secret-32chars

# Supabase (same as guard-brasil-web)
SUPABASE_URL=https://lhscgsqhiooyatkebose.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://lhscgsqhiooyatkebose.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# X.com API (read + write)
X_BEARER_TOKEN=your-bearer-token
X_API_KEY=your-api-key
X_API_SECRET=your-api-secret
X_ACCESS_TOKEN=your-access-token
X_ACCESS_TOKEN_SECRET=your-access-token-secret
X_USER_ID=your-x-user-id

# Agent Registry (path to agents.json — absolute path on VPS)
# AGENTS_REGISTRY_PATH=/opt/egos/agents/registry/agents.json

# Node env
NODE_ENV=production
