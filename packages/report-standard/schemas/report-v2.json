{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://egos.ia.br/schemas/report-v2.json",
  "title": "EGOS Report Schema v2.0.0",
  "description": "Canonical report format for EGOS ecosystem",
  "type": "object",
  "required": ["id", "type", "version", "title", "created_at", "updated_at", "authors", "sections"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique report identifier"
    },
    "type": {
      "type": "string",
      "enum": ["analytics", "audit", "compliance", "dissemination", "incident", "intelligence", "research", "strategy", "technical"],
      "description": "Report classification"
    },
    "version": {
      "type": "string",
      "default": "2.0.0",
      "description": "Schema version"
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 200,
      "description": "Report title"
    },
    "description": {
      "type": "string",
      "description": "Optional report description"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp"
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/ReportAuthor"
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ReportSection"
      }
    },
    "insights": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ReportInsight"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ReportSource"
      }
    },
    "validation": {
      "$ref": "#/definitions/ValidationInfo"
    },
    "dissemination": {
      "$ref": "#/definitions/DisseminationInfo"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "definitions": {
    "ReportAuthor": {
      "type": "object",
      "required": ["id", "name", "role"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "agent_id": { "type": "string" },
        "signature": { "type": "string" }
      }
    },
    "ReportSection": {
      "type": "object",
      "required": ["type", "title", "content", "order"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["executive_summary", "methodology", "findings", "recommendations", "appendix", "metadata"]
        },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "order": { "type": "integer", "minimum": 0 },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/definitions/ReportSource" }
        },
        "insights": {
          "type": "array",
          "items": { "type": "string", "format": "uuid" }
        }
      }
    },
    "ReportInsight": {
      "type": "object",
      "required": ["id", "type", "description", "evidence", "confidence"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "type": {
          "type": "string",
          "enum": ["pattern", "anomaly", "opportunity", "risk", "trend"]
        },
        "description": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/definitions/ReportSource" }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "related_insights": {
          "type": "array",
          "items": { "type": "string", "format": "uuid" }
        }
      }
    },
    "ReportSource": {
      "type": "object",
      "required": ["type", "path"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["file", "url", "database", "api", "manual"]
        },
        "path": { "type": "string" },
        "hash": { "type": "string" },
        "collected_at": { "type": "string", "format": "date-time" },
        "verified_by": { "type": "string" }
      }
    },
    "ValidationInfo": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["draft", "pending_review", "validated", "rejected"]
        },
        "validated_by": { "type": "string" },
        "validated_at": { "type": "string", "format": "date-time" },
        "validator_version": { "type": "string" }
      }
    },
    "DisseminationInfo": {
      "type": "object",
      "properties": {
        "records": {
          "type": "array",
          "items": { "$ref": "#/definitions/DisseminationRecord" }
        },
        "auto_disseminate": { "type": "boolean", "default": false },
        "channels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["github", "telegram", "email", "webhook", "mcp"]
          }
        }
      }
    },
    "DisseminationRecord": {
      "type": "object",
      "required": ["channel", "target", "status"],
      "properties": {
        "channel": {
          "type": "string",
          "enum": ["github", "telegram", "email", "webhook", "mcp"]
        },
        "target": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pending", "sent", "delivered", "failed"]
        },
        "sent_at": { "type": "string", "format": "date-time" },
        "delivered_at": { "type": "string", "format": "date-time" },
        "error": { "type": "string" }
      }
    }
  }
}
