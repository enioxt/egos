#!/bin/sh
# .husky/post-commit — EGOS auto-disseminate after every commit
#
# Runs auto-disseminate.sh to:
#   - Mark task IDs found in commit message as done in TASKS.md
#   - Append LEARNING: lines to docs/knowledge/HARVEST.md
#   - Warn if a new feat() is missing from CAPABILITY_REGISTRY.md
#
# Non-blocking: never fails the commit. Errors are logged only.

bash scripts/auto-disseminate.sh 2>/dev/null || true

# DISS-004 + DISS-002: trigger kernel scanner when governance files change,
# then auto-propagate to all existing leaf repos (rollback-safe: --no-verify, one commit per repo)
STAGED_KERNEL=$(git diff --name-only HEAD~1 HEAD 2>/dev/null \
  | grep -E '^(CLAUDE\.md|\.windsurfrules|docs/CAPABILITY_REGISTRY\.md|~/.claude/CLAUDE\.md)$' || true)

if [ -n "$STAGED_KERNEL" ]; then
  echo "[post-commit] Kernel file changed ($STAGED_KERNEL) — scanning + propagating..."
  if bun scripts/disseminate-scanner.ts 2>/dev/null; then
    echo "[post-commit] No propagation needed (no manifest generated)"
  else
    # manifest was written — auto-propagate in background (non-blocking)
    echo "[post-commit] Manifest written — auto-propagating to leaf repos (background)..."
    bun scripts/disseminate-propagator.ts --all > /tmp/egos-propagate-$(date +%Y%m%d-%H%M%S).log 2>&1 &
    echo "[post-commit] Propagation started in background. Log: /tmp/egos-propagate-*.log"
  fi
fi
