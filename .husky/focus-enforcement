  "intelink"
  "DHPP/"
  "EGOSystem"
  "Pochete2.0"
  "guia-INPI"
  "chacreamento"
)

# Get staged files
STAGED_FILES=$(git diff --cached --name-only)

# Color codes for terminal output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Check each staged file
VIOLATION=0

for file in $STAGED_FILES; do
  # Skip deletion commits
  if [ ! -f "$file" ]; then
    continue
  fi

  # Check if file matches forbidden patterns
  for forbidden in "${FORBIDDEN_PATTERNS[@]}"; do
    if [[ "$file" == *"$forbidden"* ]]; then
      VIOLATION=1
      echo -e "${RED}вќЊ FOCUS ENFORCEMENT VIOLATION${NC}"
      echo -e "${RED}File: $file${NC}"
      echo -e "${YELLOW}This file matches forbidden pattern: $forbidden${NC}"
      echo ""
      break
    fi
  done

  # If not forbidden, check if it matches allowed patterns
  if [ $VIOLATION -eq 0 ]; then
    ALLOWED=0
    for allowed in "${ALLOWED_PATTERNS[@]}"; do
      if [[ "$file" == *"$allowed"* ]]; then
        ALLOWED=1
        break
      fi
    done

    if [ $ALLOWED -eq 0 ]; then
      VIOLATION=1
      echo -e "${RED}вќЊ FOCUS ENFORCEMENT VIOLATION${NC}"
      echo -e "${RED}File: $file${NC}"
      echo -e "${YELLOW}This file is outside Guard Brasil + Gem Hunter focus${NC}"
      echo ""
    fi
  fi
done

# If violations found, print guidance and exit
if [ $VIOLATION -eq 1 ]; then
  echo ""
  echo -e "${BLUE}в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ${NC}"
  echo -e "${BLUE}FOCUS ENFORCEMENT вЂ” 90-Day Strategic Commitment${NC}"
  echo -e "${BLUE}в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ${NC}"
  echo ""
  echo -e "${GREEN}вњ… ALLOWED (Next 90 days):${NC}"
  echo "  вЂў Guard Brasil API + Web + Infrastructure"
  echo "  вЂў Gem Hunter (algorithm, GitHub app, dashboard)"
  echo "  вЂў Supporting telemetry, QA, CI/CD"
  echo "  вЂў Strategic documentation (planning, analysis)"
  echo ""
  echo -e "${RED}вќЊ FORBIDDEN (Until June 30, 2026):${NC}"
  echo "  вЂў ARCH (architectural design AI)"
  echo "  вЂў egos-self (personal OS)"
  echo "  вЂў smartbuscas (smart search)"
  echo "  вЂў FORJA (ERP)"
  echo "  вЂў EGOSv2, v3, v5 (old versions)"
  echo "  вЂў BLUEPRINT-EGOS, egos-cortex, intelink"
  echo "  вЂў Any new repos or experiments"
  echo ""
  echo -e "${YELLOW}вЏ° PERIOD: April 3 - June 30, 2026${NC}"
  echo -e "${YELLOW}рџЋЇ GOAL: R\$ 30k+ MRR from Guard Brasil + Gem Hunter${NC}"
  echo ""
  echo -e "${BLUE}WHY THIS MATTERS:${NC}"
  echo "  You have 20 repos but focus on none."
  echo "  This rule forces you to FINISH instead of START."
  echo "  The constraint is intentional and unbreakable."
  echo ""
  echo -e "${BLUE}EXCEPTION (Critical Bugs Only):${NC}"
  echo "  If 852, carteira-livre, or egos-lab have security issues,"
  echo "  you may commit fixes. Include [CRITICAL] in commit message."
  echo ""
