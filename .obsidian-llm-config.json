{
  "name": "EGOS Obsidian LLM Config",
  "providers": {
    "alibaba": {
      "name": "Alibaba DashScope",
      "base_url": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
      "api_key_env": "ALIBABA_API_KEY",
      "models": {
        "qwen-plus": {
          "name": "Qwen Plus",
          "max_tokens": 8192,
          "context_window": 131072
        },
        "qwen-max": {
          "name": "Qwen Max",
          "max_tokens": 8192,
          "context_window": 32768
        },
        "qwen-turbo": {
          "name": "Qwen Turbo",
          "max_tokens": 8192,
          "context_window": 8192
        }
      }
    },
    "openrouter": {
      "name": "OpenRouter",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "models": {
        "anthropic/claude-3.7-sonnet": {
          "name": "Claude 3.7 Sonnet",
          "max_tokens": 8192
        },
        "openai/gpt-4o": {
          "name": "GPT-4o",
          "max_tokens": 8192
        }
      }
    }
  },
  "obsidian_copilot": {
    "default_provider": "alibaba",
    "default_model": "qwen-plus",
    "custom_model_url": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
  }
}
