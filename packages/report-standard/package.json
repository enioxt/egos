{
  "name": "@egos/report-standard",
  "version": "1.0.0",
  "description": "EGOS Report SSOT v2.0.0 — Canonical report schema, validator, and types",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "validate": "bun run src/validate.ts"
  },
  "keywords": ["egos", "report", "ssot", "standard"],
  "author": "EGOS Team",
  "license": "MIT",
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "bun-types": "latest"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema.js",
      "types": "./dist/schema.d.ts"
    },
    "./validator": {
      "import": "./dist/validator.js",
      "types": "./dist/validator.d.ts"
    }
  }
}
