{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@egos/shared": ["./packages/shared/src"],
      "@egos/shared/*": ["./packages/shared/src/*"]
    }
  },
  "include": [
    "agents/**/*.ts",
    "packages/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
