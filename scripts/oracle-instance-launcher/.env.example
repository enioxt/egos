OCI_AUTH_MODE=api_key
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT
OCI_REGION=us-ashburn-1
OCI_TENANCY_OCID=
OCI_USER_OCID=
OCI_FINGERPRINT=
OCI_PRIVATE_KEY_PATH=
OCI_PRIVATE_KEY_PASSPHRASE=
OCI_COMPARTMENT_ID=
OCI_SUBNET_ID=
OCI_VCN_ID=
OCI_IMAGE_ID=
OCI_IMAGE_AUTODETECT=true
OCI_IMAGE_OS=Canonical Ubuntu
OCI_IMAGE_VERSION=24.04
OCI_SSH_PUBLIC_KEY_FILE=
OCI_SSH_PUBLIC_KEY=
OCI_DISPLAY_NAME=egos-a1-free
OCI_HOSTNAME_LABEL=egos-a1-free
OCI_SHAPE=VM.Standard.A1.Flex
OCI_OCPUS=1
OCI_MEMORY_GB=6
OCI_BOOT_VOLUME_GB=50
