#!/bin/bash
# ============================================================================
# FOCUS ENFORCEMENT HOOK v3.0 — Single Pursuit Protocol
# Period: April 11 - July 11, 2026
#
# v3.0 CHANGE: Single Pursuit — Guard Brasil Hybrid
#   FORBIDDEN list  → HARD BLOCK (same as before, named traps)
#   Guard Brasil    → CLEAN PASS (no warning)
#   Gem Hunter      → WEEKLY CAP warning (max 3 commits/week)
#   Everything else → STRONG WARNING with dispersal counter
#
# Principio: "Foco compoem. Dispersao dissipa." (Rian Doris)
# ============================================================================

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

# ── FORBIDDEN: Hard block (same products as v2.0) ─────────────────────────
FORBIDDEN_PATTERNS=(
  "ARCH/" "egos-self" "smartbuscas" "EGOSv2" "EGOSv3" "EGOSv5"
  "BLUEPRINT-EGOS" "egos-cortex" "intelink" "DHPP/" "EGOSystem"
  "Pochete2.0" "guia-INPI" "chacreamento"
)

# ── GUARD BRASIL: The single pursuit (clean pass) ─────────────────────────
GUARD_PATTERNS=(
  "guard-brasil" "apps/api" "packages/guard-brasil"
  "docs/strategy/GUARD" "docs/products/guard"
)

# ── MAINTENANCE: Allowed with no fuss ─────────────────────────────────────
MAINT_PATTERNS=(
  "TASKS.md" "AGENTS.md" "CLAUDE.md" ".claude/" ".guarani/" ".husky/"
  "scripts/" "packages/shared" "packages/mcp" "docs/knowledge/HARVEST"
  ".github/" "package.json" "tsconfig" "bun.lock" ".windsurfrules"
  "docs/_current_handoffs" "docs/jobs/" "docs/SYSTEM_MAP" "docs/CAPABILITY_REGISTRY"
  ".agents/" ".windsurf/" "docs/audit/" "docs/agents/"
)

# ── GEM HUNTER: Weekly cap (warn after 3 commits/week) ────────────────────
GEM_PATTERNS=("gem-hunter" "gem_hunter")

STAGED_FILES=$(git diff --cached --name-only)
FORBIDDEN_HIT=0
GUARD_COUNT=0
GEM_COUNT=0
OTHER_FILES=()

for file in $STAGED_FILES; do
  [ ! -f "$file" ] && continue

  # 1. Hard block forbidden products
  for forbidden in "${FORBIDDEN_PATTERNS[@]}"; do
    if [[ "$file" == *"$forbidden"* ]]; then
      FORBIDDEN_HIT=1
      echo -e "${RED}❌ FOCO VIOLADO: $file → $forbidden${NC}"
    fi
  done
  [ $FORBIDDEN_HIT -eq 1 ] && continue

  # 2. Guard Brasil = clean pass
  IS_GUARD=0
  for gp in "${GUARD_PATTERNS[@]}"; do
    [[ "$file" == *"$gp"* ]] && { IS_GUARD=1; GUARD_COUNT=$((GUARD_COUNT+1)); break; }
  done
  [ $IS_GUARD -eq 1 ] && continue

  # 3. Gem Hunter = weekly cap check
  IS_GEM=0
  for gmp in "${GEM_PATTERNS[@]}"; do
    [[ "$file" == *"$gmp"* ]] && { IS_GEM=1; GEM_COUNT=$((GEM_COUNT+1)); break; }
  done
  [ $IS_GEM -eq 1 ] && continue

  # 4. Maintenance = silent pass
  IS_MAINT=0
  for mp in "${MAINT_PATTERNS[@]}"; do
    [[ "$file" == *"$mp"* ]] && { IS_MAINT=1; break; }
  done
  [ $IS_MAINT -eq 1 ] && continue

  # 5. Everything else = dispersal warning
  OTHER_FILES+=("$file")
done

# ── HARD BLOCK (forbidden) ────────────────────────────────────────────────
if [ $FORBIDDEN_HIT -eq 1 ]; then
  echo -e "${RED}═══════════════════════════════════════════════════════════${NC}"
  echo -e "${RED}SINGLE PURSUIT v3.0 — Produto proibido até Jul 2026${NC}"
  echo -e "${RED}═══════════════════════════════════════════════════════════${NC}"
  exit 1
fi

# ── GEM HUNTER WEEKLY CAP WARNING ─────────────────────────────────────────
if [ $GEM_COUNT -gt 0 ]; then
  GEM_WEEK=$(git log --oneline --since="7 days ago" -- '*gem-hunter*' '*gem_hunter*' 2>/dev/null | wc -l)
  if [ "$GEM_WEEK" -ge 3 ]; then
    echo -e "${YELLOW}🎮 GEM HUNTER: $GEM_WEEK commits esta semana (max recomendado: 3)${NC}"
    echo -e "${YELLOW}   Lembre-se: Gem Hunter = hobby de dopamina (2h/semana, sexta-feira)${NC}"
    echo -e "${YELLOW}   Nao e projeto. E jiu-jitsu digital. Commit permitido mas ATENCAO.${NC}"
  fi
fi

# ── DISPERSAL WARNING (strong but non-blocking) ──────────────────────────
if [ ${#OTHER_FILES[@]} -gt 0 ]; then
  # Count Guard Brasil commits this week vs total
  GUARD_WEEK=$(git log --oneline --since="7 days ago" -- 'packages/guard-brasil/*' 'apps/api/*' 2>/dev/null | wc -l)
  TOTAL_WEEK=$(git log --oneline --since="7 days ago" 2>/dev/null | wc -l)

  echo ""
  echo -e "${YELLOW}${BOLD}⚠️  ALERTA DE DISPERSAO (commit permitido)${NC}"
  echo -e "${YELLOW}   Arquivos FORA do Guard Brasil:${NC}"
  for wf in "${OTHER_FILES[@]}"; do
    echo -e "${YELLOW}   → $wf${NC}"
  done
  echo ""
  echo -e "${BLUE}   📊 Guard Brasil esta semana: $GUARD_WEEK commits de $TOTAL_WEEK total${NC}"
  if [ "$TOTAL_WEEK" -gt 0 ]; then
    RATIO=$((GUARD_WEEK * 100 / TOTAL_WEEK))
    if [ "$RATIO" -lt 60 ]; then
      echo -e "${RED}   🔴 RATIO: ${RATIO}% Guard Brasil (target: >60%)${NC}"
      echo -e "${RED}   Voce esta dispersando. Volte pro Guard Brasil.${NC}"
    else
      echo -e "${GREEN}   🟢 RATIO: ${RATIO}% Guard Brasil — bom foco${NC}"
    fi
  fi
  echo -e "${BLUE}   Meta: 1 cliente pagante em 30 dias. Cada hora conta.${NC}"
  echo ""
fi

echo -e "${GREEN}✅ Focus enforcement check passed${NC}"
exit 0