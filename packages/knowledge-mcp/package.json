{
  "name": "@egosbr/knowledge-mcp",
  "version": "1.1.0",
  "description": "EGOS Knowledge Base MCP server — ingest PDFs/docs, search, Q&A, lint, export",
  "type": "module",
  "main": "./dist/mcp-server.js",
  "bin": {
    "knowledge-mcp": "./dist/mcp-server.js"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "build": "bun build --bundle --target=node --outfile=dist/mcp-server.js src/index.ts && chmod +x dist/mcp-server.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist/mcp-server.js",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "knowledge-base",
    "claude",
    "egos",
    "brazil",
    "lgpd",
    "notion"
  ],
  "author": "Enio Rocha <enio@egos.ia.br>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/enioxt/egos.git",
    "directory": "packages/knowledge-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "mammoth": "^1.12.0",
    "unpdf": "^1.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
